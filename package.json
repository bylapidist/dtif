{
  "name": "@lapidist/dtif",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "node tests/tooling/snapshot-serializer.test.mjs && node tests/tooling/run.mjs && node tests/tooling/validate-examples.mjs",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "lint": "markdownlint \"**/*.md\" --ignore \"**/node_modules/**\"",
    "lint:fix": "markdownlint --fix \"**/*.md\" --ignore \"**/node_modules/**\"",
    "lint:ts": "eslint .",
    "lint:parser": "eslint parser",
    "lint:language-server": "eslint language-server",
    "typecheck": "pnpm -r --if-present run typecheck",
    "validate:dtif": "node scripts/validate-markdown-dtif.mjs",
    "build": "pnpm run build:packages",
    "build:parser": "pnpm --filter @lapidist/dtif-parser run build",
    "build:language-server": "pnpm --filter @lapidist/dtif-language-server run build",
    "build:packages": "node scripts/build-packages.mjs",
    "test:parser": "pnpm --filter @lapidist/dtif-parser test",
    "test:language-server": "pnpm --filter @lapidist/dtif-language-server test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint:docs": "markdownlint \"docs/**/*.md\"",
    "changeset": "changeset",
    "release": "changeset publish",
    "version-packages": "changeset version && pnpm install --lockfile-only"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@dtsgenerator/replace-namespace": "1.7.0",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "ajv-cli": "5.0.0",
    "ajv-formats": "3.0.1",
    "dtsgenerator": "3.19.2",
    "eslint": "10.2.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vitepress": "1.6.4"
  }
}
